{
  "name": "lenscn",
  "version": "0.0.1",
  "description": "True optical refraction glass for the web. SVG feDisplacementMap based, works in every modern browser.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dushaobindoudou/lenscn.git",
    "directory": "packages/lenscn"
  },
  "homepage": "https://dushaobindoudou.github.io/lenscn/",
  "bugs": "https://github.com/dushaobindoudou/lenscn/issues",
  "keywords": [
    "glass",
    "glassmorphism",
    "liquid-glass",
    "frosted-glass",
    "refraction",
    "lens",
    "displacement-map",
    "fedisplacementmap",
    "svg-filter",
    "ui",
    "design-system"
  ]
}
